{
    "name": "bjornbasar/karhu",
    "description": "Minimal PHP microframework — attribute-routed, zero dependencies, PHP 8.3+",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Bjorn Basar",
            "email": "bjorn@basar.co.nz"
        }
    ],
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Karhu\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Karhu\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@cs-check",
            "@analyse",
            "@test"
        ]
    }
}
